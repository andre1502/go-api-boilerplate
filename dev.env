APP_NAME=GOAPI
SERVER_URL=http://127.0.0.1:9000
SERVER_ADDRESS=:9000

SCHEDULER_HEALTH_SERVER_ADDRESS=:9001
SCHEDULE_REDIS_PREFIX=Schedule:

# Cloud Storage
MAX_FILE_SIZE_MB=5
MAX_FILE_COUNT=10
GCP_CLOUD_STORAGE_BUCKET_NAME=dev-cdn.go.api

# JWT
JWT_SECRET_KEY=JWT_SECRET_KEY
JWT_ALGORITHM=HS256
PLATFORM_JWT_EXPIRE_MINUTES=4320
BACKOFFICE_JWT_EXPIRE_MINUTES=2880

# MySQL
DATABASE_URL=root:root@tcp(localhost:3306)/goapi?parseTime=true&loc=UTC

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=GoApi:

# elastic
ELASTIC_URL=http://localhost:9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=zAU47tPtlh9ZxcsU

# KAIA
KAIA_ENDPOINT=https://public-en-kairos.node.kaia.io
# DO NOT include 0x prefix
